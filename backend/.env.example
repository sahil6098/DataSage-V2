# Copy to `.env` and fill in real values.

APP_NAME=DataSage API
ENVIRONMENT=development
DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<optional-db>
MONGODB_DATABASE=datasage

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ENCRYPTION_KEY=replace-with-a-32-byte-secret-or-a-fernet-key

# Uploads
UPLOAD_DIR=backend/storage/uploads
MAX_UPLOAD_SIZE_MB=25
PREVIEW_ROW_LIMIT=200
MAX_USER_MESSAGE_TOKENS=1200
MAX_CHAT_RESULT_ROWS=200

# LLM providers
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=45
GEMINI_REQUESTS_PER_MINUTE=10
GROQ_REQUESTS_PER_MINUTE=20
GEMINI_TOKENS_PER_MINUTE=200000
GROQ_TOKENS_PER_MINUTE=200000
